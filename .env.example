# Copy to backend/django-platform/.env for local development.
# Skopiuj do backend/django-platform/.env na potrzeby lokalnego developmentu.
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-for-local-development-only
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=

# Future Docker Compose PostgreSQL settings / Ustawienia przyszłego etapu Docker Compose
POSTGRES_DB=logiflow
POSTGRES_USER=logiflow
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
